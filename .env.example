# =============================================================================
# THE QUICK REVIEWER - ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# AI PROVIDER CONFIGURATION
# -----------------------------------------------------------------------------

# Primary AI provider to use for review generation
# Options: "perplexity", "openai", "gemini"
# Default: perplexity (recommended for web grounding)
AI_PROVIDER=perplexity

# AI model to use (provider-specific)
# Perplexity: sonar-pro, sonar, sonar-reasoning, sonar-deep-research
# OpenAI: gpt-5, gpt-5-mini, gpt-5-nano, gpt-4.1, gpt-4.1-mini, gpt-4o, gpt-4o-mini, gpt-3.5-turbo
# Gemini: gemini-2.5-flash-lite, gemini-2.5-flash, gemini-2.5-pro
# Default: sonar-pro (for Perplexity), gpt-4.1 (for OpenAI), gemini-2.5-flash-lite (for Gemini)
AI_MODEL=sonar-pro

# -----------------------------------------------------------------------------
# API KEYS (At least one required based on AI_PROVIDER setting)
# -----------------------------------------------------------------------------

# Perplexity API Key (Required if AI_PROVIDER=perplexity)
# Get from: https://www.perplexity.ai/settings/api
# Pro subscription ($20/month) required for API access
PERPLEXITY_API_KEY=pplx-your_perplexity_api_key_here

# OpenAI API Key (Required if AI_PROVIDER=openai)
# Get from: https://platform.openai.com/api-keys
# Pay-per-use pricing
OPENAI_API_KEY=sk-your_openai_api_key_here

# Google Gemini API Key (Required if AI_PROVIDER=gemini)
# Get from: https://aistudio.google.com/app/apikey
# Free tier available with limits
GEMINI_API_KEY=your_google_api_key_here

# -----------------------------------------------------------------------------
# METADATA SERVICES (Required)
# -----------------------------------------------------------------------------

# TMDB API Key (Required) - Primary movie metadata source
# Get from: https://www.themoviedb.org/settings/api
# Free registration required
TMDB_API_KEY=your_tmdb_api_key_here

# OMDB API Key (Required) - Fallback metadata source  
# Get from: http://www.omdbapi.com/apikey.aspx
# Free tier: 1000 requests/day, Paid: $10/month for more
OMDB_API_KEY=your_omdb_api_key_here

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION (Optional)
# -----------------------------------------------------------------------------

# Port for the addon server
# Default: 7850
PORT=7850

# Base URL for the addon (Optional)
# Used for generating absolute URLs in responses
# If not set, will auto-detect from request headers
# Examples: https://your-domain.com, https://your-app.herokuapp.com
BASE_URL=

# Hugging Face Spaces URL (Optional)
# Alternative to BASE_URL for HF deployments
HF_SPACE_URL=

# -----------------------------------------------------------------------------
# SECURITY (Optional)
# -----------------------------------------------------------------------------

# Addon password protection (Optional)
# If set, all addon endpoints will require this password
# Enables IP-based rate limiting and password protection
ADDON_PASSWORD=

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (Optional)
# -----------------------------------------------------------------------------

# Database connection URI (Optional)
# Options:
#   - sqlite:///data/reviews.db (default - file-based SQLite)
#   - postgresql://user:password@host:port/database
#   - Leave empty for in-memory storage (not recommended for production)
DATABASE_URI=sqlite:///data/reviews.db

# -----------------------------------------------------------------------------
# PERFORMANCE TUNING (Optional)
# -----------------------------------------------------------------------------

# AI generation timeout in milliseconds
# Default: 13000 (13 seconds)
ADDON_TIMEOUT_MS=13000

# Cache expiry time in milliseconds
# Default: 2592000000 (30 days)
CACHE_EXPIRY_MS=2592000000

# -----------------------------------------------------------------------------
# DEBUG CONFIGURATION (Optional - for development/troubleshooting)
# -----------------------------------------------------------------------------

# Enable full prompt logging to console
# Set to "true" to log the complete prompt sent to AI
# Default: false (disable in production)
DEBUG_PROMPT=false

# Enable raw AI response logging to console  
# Set to "true" to log complete AI response structure
# Default: false (disable in production - can be verbose)
DEBUG_RESPONSE=false

# Enable HTTP debug logging
# Set to "true" for detailed HTTP request/response logs
# Default: false
DEBUG_HTTP=false

# -----------------------------------------------------------------------------
# NODE.js ENVIRONMENT (Optional)
# -----------------------------------------------------------------------------

# Node environment
# Options: development, production, test
# Default: production
NODE_ENV=production

# -----------------------------------------------------------------------------
# USAGE NOTES
# -----------------------------------------------------------------------------

# MINIMUM REQUIRED for basic functionality:
# - AI_PROVIDER=perplexity
# - PERPLEXITY_API_KEY=your_key
# - TMDB_API_KEY=your_key  
# - OMDB_API_KEY=your_key

# RECOMMENDED for production:
# - Set DATABASE_URI to persistent storage
# - Set ADDON_PASSWORD for security
# - Set BASE_URL for proper URL generation
# - Keep DEBUG_* variables as false

# COST CONSIDERATIONS:
# - Perplexity Pro: $20/month (includes $5 API credits)
# - OpenAI: Pay-per-use (varies by model)
# - TMDB: Free
# - OMDB: Free tier 1000/day, $10/month unlimited
# - Gemini: Free tier available

# PROVIDER RECOMMENDATIONS:
# - Best web grounding: Perplexity (sonar-pro model)
# - Most advanced reasoning: OpenAI (gpt-5 model)  
# - Cost-effective: Gemini (gemini-2.5-flash-lite model)
